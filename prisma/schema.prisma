// Gate - Prisma Schema
// PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  PREMIUM
  FREE
}

enum LinkRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RelationType {
  PARENT_CHILD
  SPOUSE
  CUSTOM
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum ExportType {
  ASCENDANCE
  DESCENDANCE
  MIXTE
  CUSTOM
}

enum ReportType {
  ERROR
  ADDITION
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_UPGRADED
  USER_DOWNGRADED
  PERSON_CREATED
  PERSON_UPDATED
  PERSON_DELETED
  LINK_REQUEST_CREATED
  LINK_REQUEST_APPROVED
  LINK_REQUEST_REJECTED
  EXPORT_CREATED
  IMPORT_DONE
  ADMIN_ACTION
  VISIBILITY_TOGGLED
  REPORT_SUBMITTED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  name              String?
  password          String?
  image             String?
  role              Role      @default(FREE)
  searchCount       Int       @default(0)
  exportCount       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // NextAuth
  accounts          Account[]
  sessions          Session[]

  // App
  person            Person?       @relation("UserPerson")
  linkRequests      LinkRequest[] @relation("UserLinkRequests")
  subscription      Subscription?
  consentLogs       ConsentLog[]
  auditLogs         AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailVerificationCode {
  id         String   @id @default(cuid())
  email      String
  code       String
  expires    DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([email])
  @@map("email_verification_codes")
}

model Person {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  gender        Gender    @default(UNKNOWN)
  birthDate     DateTime?
  deathDate     DateTime?
  birthPlace    String?
  deathPlace    String?
  photoUrl      String?
  description   String?   @db.Text
  isAlive       Boolean   @default(true)

  // Visibility toggles (controlled by ADMIN)
  showBirthDate   Boolean @default(false)
  showDeathDate   Boolean @default(false)
  showMarriage    Boolean @default(false)
  showPhoto       Boolean @default(false)
  showPersonalData Boolean @default(false)

  // Linked user (1 seul user par profil)
  userId        String?   @unique
  user          User?     @relation("UserPerson", fields: [userId], references: [id])

  // Relations
  relationsAsSource  Relation[] @relation("RelationSource")
  relationsAsTarget  Relation[] @relation("RelationTarget")

  // Link requests
  linkRequests  LinkRequest[]

  // Reports
  reports       Report[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("persons")
}

model Relation {
  id           String       @id @default(cuid())
  sourceId     String
  targetId     String
  type         RelationType
  label        String?      // Pour les relations custom
  marriageDate DateTime?
  divorceDate  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  source Person @relation("RelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Person @relation("RelationTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
  @@map("relations")
}

model LinkRequest {
  id        String            @id @default(cuid())
  userId    String
  personId  String
  message   String            @db.Text
  status    LinkRequestStatus @default(PENDING)
  adminMessage String?        @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user   User   @relation("UserLinkRequests", fields: [userId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("link_requests")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  status               String    @default("inactive") // active, inactive, past_due, canceled
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model ConsentLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "rgpd", "terms", "marketing"
  accepted  Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consent_logs")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  entity    String?     // nom de la table/entité concernée
  entityId  String?     // id de l'entité concernée
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Report {
  id          String   @id @default(cuid())
  personId    String
  type        ReportType @default(ERROR)
  errorType   String?
  reporterEmail String?
  message     String   @db.Text
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model ImportJob {
  id         String   @id @default(cuid())
  fileName   String
  status     String   @default("pending") // pending, processing, done, error
  totalRows  Int      @default(0)
  processed  Int      @default(0)
  errors     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("import_jobs")
}
