generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS - Énumérations
// ============================================================================

/// Rôles utilisateurs pour la gestion des accès et limites
/// - ADMIN: Accès complet, gestion de la plateforme
/// - PREMIUM: Accès abonnement payant, limites élevées
/// - FREE: Accès gratuit avec limites (5 recherches, 10 profils, 1 export)
enum Role {
  ADMIN
  PREMIUM
  FREE
}

/// États du cycle de vie des demandes de rattachement
/// - PENDING: En attente de traitement par un admin
/// - APPROVED: Approuvée, l'utilisateur est lié au profil
/// - REJECTED: Rejetée, l'utilisateur ne peut pas se lier à ce profil
enum LinkRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Types de relations familiales
/// - PARENT_CHILD: Relation parent-enfant
/// - SPOUSE: Relation conjugale (mariage)
/// - CUSTOM: Relation personnalisée (ex: parrain/marraine)
enum RelationType {
  PARENT_CHILD
  SPOUSE
  CUSTOM
}

/// Genres des personnes dans l'arbre généalogique
enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

/// Types d'exports de données généalogiques
/// - ASCENDANCE: Ancêtres uniquement
/// - DESCENDANCE: Descendants uniquement
/// - MIXTE: Ascendants + descendants
/// - CUSTOM: Export personnalisé
enum ExportType {
  ASCENDANCE
  DESCENDANCE
  MIXTE
  CUSTOM
}

/// Types de rapports/signalements
/// - ERROR: Erreur dans les données
/// - ADDITION: Suggestion d'ajout
enum ReportType {
  ERROR
  ADDITION
}

/// Actions d'audit pour traçabilité complète des opérations
enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_UPGRADED
  USER_DOWNGRADED
  PERSON_CREATED
  PERSON_UPDATED
  PERSON_DELETED
  LINK_REQUEST_CREATED
  LINK_REQUEST_APPROVED
  LINK_REQUEST_REJECTED
  EXPORT_CREATED
  IMPORT_DONE
  ADMIN_ACTION
  VISIBILITY_TOGGLED
  REPORT_SUBMITTED
}

// ============================================================================
// MODÈLES - NextAuth (Auth & Sessions)
// ============================================================================

/// Modèle User: Utilisateurs du système
/// Gère les authentifications (credentials, magic link) et les rôles
/// - searchCount, exportCount: Suivi des limites FREE/PREMIUM
/// - EmailVerified: Nécessaire pour l'authentification
/// - role: Détermine les accès et limites (source de vérité: webhooks Stripe)
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  name              String?
  password          String?                // Hash bcrypt pour CredentialsProvider
  image             String?
  role              Role      @default(FREE)    // Rôle par défaut FREE, changé par Stripe webhook
  searchCount       Int       @default(0)       // Limites FREE: 5 / PREMIUM: illimité
  exportCount       Int       @default(0)       // Limites FREE: 1 / PREMIUM: illimité
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // NextAuth relations
  accounts          Account[]     // OAuth providers
  sessions          Session[]     // Sessions JWT

  // App relations
  person            Person?       @relation("UserPerson")           // 1 utilisateur = 1 profil max
  linkRequests      LinkRequest[] @relation("UserLinkRequests")     // Demandes de rattachement
  subscription      Subscription?                                     // Abonnement Stripe
  consentLogs       ConsentLog[]                                      // Historique RGPD
  auditLogs         AuditLog[]                                        // Audit trail

  @@map("users")
}

/// Modèle Account: Comptes OAuth (NextAuth)
/// Stocke les credentials OAuth pour les providers externes
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// Modèle Session: Sessions utilisateurs NextAuth
/// Gère les tokens JWT et expirations
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

/// Modèle VerificationToken: Tokens Email Provider (NextAuth)
/// Utilisé pour les magic links
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Modèle EmailVerificationCode: Codes de vérification email personnalisés
/// Utilisé lors de l'inscription (code à 6 chiffres envoyé par Resend)
model EmailVerificationCode {
  id         String   @id @default(cuid())
  email      String
  code       String
  expires    DateTime
  used       Boolean  @default(false)      // Empêche la réutilisation
  createdAt  DateTime @default(now())

  @@index([email])
  @@map("email_verification_codes")
}

// ============================================================================
// MODÈLES - Cœur de l'application (Généalogie)
// ============================================================================

/// Modèle Person: Profils généalogiques dans l'arbre
/// Représente une personne dans la base de données généalogique
/// - Peut être lié à un utilisateur via userId (1 utilisateur = 1 profil)
/// - Les toggles de visibilité sont contrôlés par les admins
/// - Relations: stockées dans le modèle Relation
model Person {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  gender        Gender    @default(UNKNOWN)
  birthDate     DateTime?
  deathDate     DateTime?
  birthPlace    String?
  deathPlace    String?
  photoUrl      String?
  description   String?   @db.Text         // Bio/description personnalisée
  profession    String?
  currentCity   String?                    // Ville de résidence actuelle

  // Contrôle de visibilité (toggles admin pour la confidentialité)
  // Ces champs permettent aux admins de masquer certaines infos sensibles même au propriétaire
  showBirthDate   Boolean @default(false)
  showDeathDate   Boolean @default(false)
  showMarriage    Boolean @default(false)
  showPhoto       Boolean @default(false)
  showPersonalData Boolean @default(false)
  isAlive         Boolean @default(true)

  // Lien avec un utilisateur (au maximum 1 utilisateur par profil)
  // Signifie que cet utilisateur "gère" ce profil
  userId        String?   @unique
  user          User?     @relation("UserPerson", fields: [userId], references: [id])

  // Relations familiales
  relationsAsSource  Relation[] @relation("RelationSource")  // Relations sortantes (ex: parent vers enfant)
  relationsAsTarget  Relation[] @relation("RelationTarget")  // Relations entrantes (ex: enfant depuis parent)

  // Demandes de rattachement d'utilisateurs
  linkRequests  LinkRequest[]

  // Signalements d'erreurs
  reports       Report[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("persons")
}

/// Modèle Relation: Relations familiales entre personnes
/// Liens généalogiques dirigés: source -> target
/// Ex: Parent (source) -> Enfant (target)
model Relation {
  id           String       @id @default(cuid())
  sourceId     String
  targetId     String
  type         RelationType              // PARENT_CHILD, SPOUSE, CUSTOM
  label        String?                   // Libellé pour les relations custom
  marriageDate DateTime?                 // Date de mariage (utile pour SPOUSE)
  divorceDate  DateTime?                 // Date de divorce
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  source Person @relation("RelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Person @relation("RelationTarget", fields: [targetId], references: [id], onDelete: Cascade)

  // Contrainte: unique sur chaque combinaison source+target+type (une seule relation de ce type entre 2 personnes)
  @@unique([sourceId, targetId, type])
  @@map("relations")
}

/// Modèle LinkRequest: Demandes de rattachement utilisateur à profil
/// Permet à un utilisateur de demander à être lié à un profil généalogique
/// Ce profil pourrait être proposé ou le profil d'un ancêtre
model LinkRequest {
  id        String            @id @default(cuid())
  userId    String
  personId  String
  message   String            @db.Text           // Message de justification de l'utilisateur
  status    LinkRequestStatus @default(PENDING)  // PENDING -> approval par admin -> APPROVED/REJECTED
  adminMessage String?        @db.Text           // Réponse de l'admin en cas de refus
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user   User   @relation("UserLinkRequests", fields: [userId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("link_requests")
}

// ============================================================================
// MODÈLES - Monétisation & Payements
// ============================================================================

/// Modèle Subscription: Gestion des abonnements Stripe
/// Stocke les infos d'abonnement Stripe pour chaque utilisateur
/// La SOURCE DE VÉRITÉ pour le rôle: webhook Stripe met à jour User.role
/// Les changements de rôle se font via le webhook Stripe, pas directement
model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique         // ID client Stripe
  stripeSubscriptionId String?   @unique         // ID abonnement Stripe
  stripePriceId        String?                    // ID du prix/plan Stripe
  stripeCurrentPeriodEnd DateTime?               // Fin de la période actuelle
  status               String    @default("inactive")  // active, inactive, past_due, canceled
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================================================
// MODÈLES - Conformité & Audit
// ============================================================================

/// Modèle ConsentLog: Logs de consentement RGPD
/// Enregistre chaque consentement utilisateur (RGPD, conditions, marketing)
/// Incluant IP et User-Agent pour audit
model ConsentLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "rgpd", "terms", "marketing"
  accepted  Boolean  // true si accepté, false si refusé
  ip        String?  // IP de l'utilisateur
  userAgent String?  // User-Agent du navigateur
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consent_logs")
}

/// Modèle AuditLog: Logs d'audit pour traçabilité
/// Enregistre TOUTES les actions importantes (créations, modifications, suppressions)
/// Utilisable pour reconstruction d'historique et conformité légale
model AuditLog {
  id        String      @id @default(cuid())
  userId    String?                     // Utilisateur qui a effectué l'action (null si système)
  action    AuditAction                 // Type d'action (USER_CREATED, PERSON_UPDATED, etc.)
  entity    String?                     // Nom de la table concernée (users, persons, etc.)
  entityId  String?                     // ID de l'entité touchée
  details   Json?                       // Détails additionnels (changements avant/après, etc.)
  ip        String?                     // IP de l'utilisateur
  userAgent String?                     // User-Agent du navigateur
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

/// Modèle Report: Signalements d'erreurs ou suggestions
/// Permet aux utilisateurs de signaler des erreurs dans les données
/// Examinés par les admins pour correction
model Report {
  id          String   @id @default(cuid())
  personId    String
  type        ReportType @default(ERROR)     // ERROR ou ADDITION
  errorType   String?                        // Type d'erreur (date invalide, doublon, etc.)
  reporterEmail String?                      // Email du signaleur (facultatif)
  message     String   @db.Text             // Description détaillée
  resolved    Boolean  @default(false)       // Marqué comme résolu par admin
  createdAt   DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("reports")
}

// ============================================================================
// MODÈLES - Imports de données
// ============================================================================

/// Modèle ImportJob: Suivi des imports CSV/Excel
/// Enregistre la progression des imports de données généalogiques massifs
model ImportJob {
  id         String   @id @default(cuid())
  fileName   String
  status     String   @default("pending")     // pending, processing, done, error
  totalRows  Int      @default(0)             // Nombre total de lignes
  processed  Int      @default(0)             // Nombre de lignes traitées
  errors     Json?                            // Erreurs rencontrées
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("import_jobs")
}
